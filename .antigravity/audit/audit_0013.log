# Get spatial_edges schema and edge counts per module
$ snip python -c "
import sqlite3
conn = sqlite3.connect('data/spatial.db')
c = conn.cursor()
# Get spatial_edges columns
c.execute('PRAGMA table_info(spatial_edges)')
print('Columns in spatial_edges:')
for col in c.fetchall():
    print(f'  {col}')
print()
# Total edges
c.execute('SELECT COUNT(*) FROM spatial_edges')
print(f'Total edges: {c.fetchone()[0]}')
# Modules with their edge counts (outgoing edges from spatial_edges)
c.execute('''
SELECT m.module_name, m.file_path, m.line_count, m.num_functions,
       COALESCE(e.edge_count, 0) as edges
FROM spatial_modules m
LEFT JOIN (
    SELECT source_module, COUNT(*) as edge_count
    FROM spatial_edges
    GROUP BY source_module
) e ON m.module_name = e.source_module
ORDER BY m.line_count DESC
''')
rows = c.fetchall()
print(f'\nAll {len(rows)} modules with edge counts:')
print('=' * 130)
for r in rows:
    print(f'{r[0]:55s} | {r[3]:3d} funcs | {r[2]:5d} lines | {r[4]:3d} edges')
print()
# Summary with edge stats
c.execute('''
SELECT COUNT(*), AVG(m.line_count), MAX(m.line_count), MIN(m.line_count),
       AVG(COALESCE(e.edge_count, 0)), MAX(COALESCE(e.edge_count, 0))
FROM spatial_modules m
LEFT JOIN (
    SELECT source_module, COUNT(*) as edge_count
    FROM spatial_edges
    GROUP BY source_module
) e ON m.module_name = e.source_module
''')
s = c.fetchone()
print('Summary:')
print(f'  Total modules: {s[0]}')
print(f'  Avg lines:     {s[1]:.1f}')
print(f'  Max lines:     {s[2]}')
print(f'  Min lines:     {s[3]}')
print(f'  Avg edges:     {s[4]:.1f}')
print(f'  Max edges:     {s[5]}')
conn.close()
"
