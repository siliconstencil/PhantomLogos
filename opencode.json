{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-wakatime",
    "@tarquinen/opencode-dcp",
    "envsitter-guard",
    "opencode-notify"
  ],
  "model": "deepseek/deepseek-v4-pro",
  "disabled_providers": [
    "openai"
  ],
  "default_agent": "build",
  "agent": {
    "build": {
      "temperature": 0.2,
      "options": {
        "reasoningEffort": 80
      }
    }
  },
  "lsp": {
    "pyright": {
      "command": [
        ".venv/Scripts/python.exe",
        "-m",
        "pyright.langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    }
  },
  "tools": {
    "websearch": true,
    "codesearch": true,
    "filesearch": true
  },
  "skills": {
    "paths": [
      "agent/skills"
    ],
    "permission": {
      "skill": {
        "*": "allow"
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    ".antigravity/topography.md",
    ".antigravity/tools.md"
  ]
}
