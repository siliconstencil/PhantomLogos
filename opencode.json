{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-wakatime",
    "@tarquinen/opencode-dcp",
    "envsitter-guard",
    "opencode-notify"
  ],
  "model": "deepseek/deepseek-v4-pro",
  "disabled_providers": [
    "openai"
  ],
  "default_agent": "build",
  "agent": {
    "build": {
      "temperature": 0.0,
      "options": {
        "reasoningEffort": 80
      }
    }
  },
  "formatter": {
    "ruff": {}
  },
  "lsp": {
    "pyright": {
      "command": [
        ".venv/Scripts/python.exe",
        "-m",
        "pyright.langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    },
    "ruff": {
      "command": [
        ".venv/Scripts/python.exe",
        "-m",
        "ruff",
        "server"
      ],
      "extensions": [
        ".py"
      ]
    }
  },
  "tools": {
    "websearch": true,
    "codesearch": true,
    "filesearch": true
  },
  "mcp": {
    "slm": {
      "type": "local",
      "command": [
        "D:\\Hank\\.venv\\Scripts\\slm.exe",
        "mcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "D:\\Hank\\.venv\\Scripts\\python.exe",
        "-m",
        "mcp_server_fetch"
      ],
      "enabled": true
    },
    "kg-mem": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "D:\\Hank\\mcp-servers\\kg-mem\\memory.json"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "D:\\Hank\\scripts\\run_github_mcp.bat"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
       "enabled": true
     },
     "filesystem": {
       "type": "local",
       "command": [
         "cmd",
         "/c",
         "npx",
         "-y",
         "@modelcontextprotocol/server-filesystem",
         "D:\\Hank"
       ],
       "enabled": true
     }
   },
  "skills": {
    "paths": [
      "agent/skills"
    ]
  },
  "instructions": [
    "AGENTS.md",
    ".antigravity/topography.md",
    ".antigravity/tools.md"
  ]
}
