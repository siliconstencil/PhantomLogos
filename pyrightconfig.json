{
    "include": [
        "."
    ],
    "exclude": [
        "**/__pycache__",
        ".venv",
        ".venv-linux",
        ".git",
        ".antigravity",
        "data",
        "projects",
        "scratch",
        "logs",
        "agent",
        "tests"
    ],
    "extraPaths": [
        "."
    ],
    "venvPath": ".",
    "venv": ".venv",
    "useLibraryCodeForTypes": true,
    "typeCheckingMode": "basic",
    "reportGeneralTypeIssues": "none",
    "reportAttributeAccessIssue": "none",
    "reportArgumentType": "none",
    "reportReturnType": "none"
}
