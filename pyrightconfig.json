{
    "include": [
        "."
    ],
    "exclude": [
        "**/__pycache__",
        ".venv",
        ".git"
    ],
    "analysis": {
        "autoSearchPaths": false,
        "extraPaths": [
            "."
        ],
        "executionEnvironments": [
            {
                "root": "."
            }
        ],
        "useLibraryCodeForTypes": true,
        "typeCheckingMode": "basic",
        "diagnosticMode": "workspace"
    }
}
