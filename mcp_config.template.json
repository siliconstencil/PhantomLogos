{
  "mcpServers": {
    "slm": {
      "command": "${PHANTOM_ROOT}\\\.venv\\Scripts\\slm.exe",
      "args": [
        "mcp"
      ],
      "env": {
        "PYTHONPATH": "${PHANTOM_ROOT}",
        "SLM_DISABLE_WARMUP_SIDE_EFFECTS": "1"
      },
      "timeout": 30,
      "enabled": false
    },
    "sequential-thinking": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {},
      "timeout": 60,
      "enabled": true
    },
    "fetch": {
      "command": "${PHANTOM_ROOT}\\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "mcp_server_fetch"
      ],
      "env": {},
      "timeout": 30,
      "enabled": true
    },
    "kg-mem": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "${PHANTOM_ROOT}\\mcp-servers\\kg-mem\\memory.json"
      },
      "timeout": 30,
      "enabled": true
    },
    "github": {
      "command": "cmd",
      "args": [
        "/c",
        "${PHANTOM_ROOT}\\scripts\\run_github_mcp.bat"
      ],
      "env": {},
      "timeout": 30,
      "enabled": true
    },
    "playwright": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "env": {},
      "timeout": 60,
      "enabled": true
    },
    "filesystem": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${PHANTOM_ROOT}"
      ],
      "env": {
        "PYTHONPATH": "${PHANTOM_ROOT}"
      }
    }
  }
}
