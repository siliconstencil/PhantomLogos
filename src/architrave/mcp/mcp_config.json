      "args": ["mcp"],
      "env": {
        "SLM_DISABLE_WARMUP_SIDE_EFFECTS": "1"
      }
    },
    "sequential-thinking": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
